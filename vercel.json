{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node",
      "config": {
        "installCommand": "npm install puppeteer --platform=linux --arch=x64"
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/papapi/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/visual/(.*)",
      "dest": "public/visual/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "assets/js/$1"
    },
    {
      "src": "/",
      "dest": "public/login.html"
    },
    {
      "src": "/app/(.*)",
      "dest": "public/index.html"
    }
  ]
}

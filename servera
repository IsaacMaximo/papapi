const puppeteer = require("puppeteer");

const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

async function scraper_pingoDoce(pagina, pesquisa) {
  const startTime = Date.now();

  const browser = await puppeteer.launch({ headless: "new" }); // "new" = mais rápido
  const page = await browser.newPage();

  await page.setUserAgent(
    "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
  );
  await page.goto(pagina, { waitUntil: "networkidle2", timeout: 60000 });

  // Fechar cookies se existir
  try {
    await page.waitForSelector('button:has-text("Aceitar")', { timeout: 3000 });
    await page.click('button:has-text("Aceitar")');
  } catch (e) {
    /* ignora */
  }

  // Buscar
  await page.waitForSelector("#header-search-bar", { timeout: 10000 });
  await page.type("#header-search-bar", pesquisa);
  await page.keyboard.press("Enter");

  await wait(3000);
  await page.waitForSelector(".product-tile-pd, .product", { timeout: 15000 });

  // Extrair produtos
  const products = await page.evaluate(() => {
    const items = document.querySelectorAll(".product-tile-pd, .product");

    return Array.from(items).map((item, index) => {
      const name =
        item.querySelector(".product-name-link a")?.innerText?.trim() || "N/A";
      const price =
        item.querySelector(".value[content]")?.getAttribute("content") ||
        item.querySelector(".price")?.innerText?.trim() ||
        "N/A";
      const image =
        item.querySelector(".product-tile-image-link img")?.src || "N/A";
      const link = item.querySelector(".product-name-link a")?.href || "N/A";

      return { id: index + 1, name, price, image, link };
    });
  });

  await browser.close();

  const executionTime = Date.now() - startTime;

  // RETORNO ORGANIZADO
  return {
    success: true,
    timestamp: new Date().toISOString(),
    search: {
      term: pesquisa,
      url: pagina,
    },
    summary: {
      total_products: products.length,
      execution_time_ms: executionTime,
    },
    products: products,
  };
}

module.exports = scraper_pingoDoce;
